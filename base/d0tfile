# base/d0tfile — d0t resource manifest
# Every managed file, hook, and package is declared here.

# ── shell ─────────────────────────────────────────────────────
link   home/.zshrc
link   home/.zshenv
link   home/.zsh_home

# ── terminal emulators ────────────────────────────────────────
link   xdg/ghostty
link   xdg/wezterm

# ── editor ────────────────────────────────────────────────────
link   xdg/nvim

# ── shell tools ───────────────────────────────────────────────
link   xdg/starship.toml
link   xdg/nushell

# ── terminal multiplexer ──────────────────────────────────────
link   home/.tmux.conf
link   xdg/tmux

# ── new tools ─────────────────────────────────────────────────
link   xdg/television/config.toml

# ── ssh — copy, not link (apps rewrite symlinked ssh configs) ─
copy   home/.ssh/config  mode=0600

# ── lifecycle hooks ───────────────────────────────────────────
hook   post-apply hooks/post-apply.sh

# ── packages ─────────────────────────────────────────────────
